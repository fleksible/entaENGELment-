{
  "name": "entaengelment",
  "version": "0.1.0",
  "description": "Consent-First Framework für resonante Multi-Agent-Systeme mit auditierbarem Proof-Protokoll (DeepJump) und Governance-Guards (G0–G6). Experimentell — kein Production-Use.",
  "author": "fleksible",
  "license": "Apache-2.0",
  "main": "main.js",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "test": "npm run test:js && npm run test:py",
    "test:js": "jest",
    "test:js:watch": "jest --watch",
    "test:js:coverage": "jest --coverage",
    "test:py": "cd Fractalsense && python -m pytest",
    "test:py:coverage": "cd Fractalsense && python -m pytest --cov --cov-report=html",
    "start": "electron .",
    "dist": "electron-builder",
    "turbo:build": "turbo run build",
    "turbo:lint": "turbo run lint",
    "turbo:typecheck": "turbo run typecheck",
    "turbo:test": "turbo run test"
  },
  "keywords": [],
  "devDependencies": {
    "electron": "43.1.0",
    "electron-builder": "^26.8.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "@testing-library/jest-dom": "^6.4.0",
    "turbo": "2.10.3"
  },
  "pnpm": {
    "overrides": {
      "form-data@>=4.0.0 <4.0.6": ">=4.0.6",
      "postcss@<8.5.10": ">=8.5.10",
      "js-yaml@<=4.1.1": ">=4.2.0",
      "undici@<6.27.0": "^6.27.0"
    }
  },
  "build": {
    "appId": "EntaENGELment",
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
